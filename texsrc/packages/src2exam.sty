\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{src2exam}[2023/11/25 v0.0.1 Src2Exam]

\RequirePackage{etoolbox}
\RequirePackage{scrlayer-scrpage}
\RequirePackage{tabularx}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}

\ExplSyntaxOn

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Package Options                                                                      %
%                                                                                      %
% Options are defined here for readability, but they are processed at the end.         %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Solutions
\DeclareOption{enablesolutions}{\enablesolutions}
\DeclareOption{disablesolutions}{\disablesolutions}

% Language
\DeclareOption{de}{\examlanguage{de}}
\DeclareOption{en}{\examlanguage{en}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Commands for using a language                                                        %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\csdef{src2exam@selectlanguage:de}{
    \csdef{src2exam@string@exam}{Klausur}
    \csdef{src2exam@string@solution}{Lösung}
    \csdef{src2exam@string@solutions}{Lösungen}
    \csdef{src2exam@string@lecture}{Vorlesung}
    \csdef{src2exam@string@course}{Kurs}
    \csdef{src2exam@string@date}{Datum}
    \csdef{src2exam@string@lecturer}{Dozent}
    \csdef{src2exam@string@semester}{Semester}
    \csdef{src2exam@string@point}{Punkt}
    \csdef{src2exam@string@points}{Punkte}
    \csdef{src2exam@string@task}{Aufgabe}
    \csdef{src2exam@string@tasks}{Aufgaben}
}

\csdef{src2exam@selectlanguage:en}{
    \csdef{src2exam@string@exam}{Exam}
    \csdef{src2exam@string@solution}{Solution}
    \csdef{src2exam@string@solutions}{Solutions}
    \csdef{src2exam@string@lecture}{Lecture}
    \csdef{src2exam@string@course}{Course}
    \csdef{src2exam@string@date}{Date}
    \csdef{src2exam@string@lecturer}{Lecturer}
    \csdef{src2exam@string@semester}{Semester}
    \csdef{src2exam@string@point}{Point}
    \csdef{src2exam@string@points}{Points}
    \csdef{src2exam@string@task}{Task}
    \csdef{src2exam@string@tasks}{Tasks}
}

\NewDocumentCommand{\examlanguage}{ m }{
    \str_case:nnF{#1}{
        {de}{\csuse{src2exam@selectlanguage:de}}
        {en}{\csuse{src2exam@selectlanguage:en}}
    }{
        \PackageError{src2exam}{
            Invalid~option~'#1'~for~\string\examlanguage.~Must~be~'de'~or~'en'.
        }{}
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Helper commands to manage singular and plural.                                       %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Singular/plural for points.
\NewDocumentCommand{\pointsstring}{
    o % points
}{
    \IfValueTF{#1}{
        \int_compare:nTF{#1 = 1}{\csuse{src2exam@string@point}}{\csuse{src2exam@string@points}}
    }{}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Commands and environments for solutions.                                             %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Toggle for solutions and commands to control them.
\newtoggle{src2exam@solutions}
\NewDocumentCommand{\setsolutions}{ m }{
    \str_case:nnF{#1}{
        {on}{\toggletrue{src2exam@solutions}}
        {off}{\togglefalse{src2exam@solutions}}
    }{
        \PackageError{src2exam}{
            Invalid~option~'#1'~for~\string\setsolutions.~Must~be~'on'~or~'off'.
        }{}
    }
}
\NewDocumentCommand{\enablesolutions}{}{\setsolutions{on}}
\NewDocumentCommand{\disablesolutions}{}{\setsolutions{off}}

% Conditionals for solutions.
\NewDocumentCommand{\ifsolutionsTF}{ m m }{
    \iftoggle{src2exam@solutions}{#1}{#2}
}
\NewDocumentCommand{\ifsolutionsT}{ m }{
    \iftoggle{src2exam@solutions}{#1}{}
}
\NewDocumentCommand{\ifsolutionsF}{ m }{
    \iftoggle{src2exam@solutions}{}{#1}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Commands and environments for tasks.                                                 %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Counter for tasks.
\newcounter{src2exam@task}

% TColorBox for a task header.
\tcbset{taskheader/.style={
    enhanced,
    colback=black!5!white,
    colframe=black!75!white,
    boxrule=0.25pt,
    %sharp corners, % TODO: why doesn't this work?
    arc=0pt,outer arc=0pt, % workaround
}}

% Typesets a task header.
\NewDocumentCommand{\taskheader}{
    o % points, typeset as [points]
    o % description
}{
    \begin{tcolorbox}[taskheader]
        \textbf{\csuse{src2exam@string@task}~\arabic{src2exam@task}}
        \IfValueT{#2}{~\textbf{(#2)}}
        \IfValueT{#1}{\hfill\textbf{[#1~\csuse{pointsstring}[#1]]}}
    \end{tcolorbox}
}

% Starts a task.
% #1: points (optional)
% #2: task description (optional)
\NewDocumentCommand{\task}{ o o }{
    \stepcounter{src2exam@task}
    \newpage
    \taskheader[#1][#2]
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Front Matter                                                                         %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Macros for exam title, course etc.
\NewDocumentCommand{\course}{ m }{\csdef{src2exam@course}{#1}}
\NewDocumentCommand{\examdate}{ m }{\csdef{src2exam@examdate}{#1}}
\NewDocumentCommand{\examtitle}{ m }{\csdef{src2exam@examtitle}{#1}}
\NewDocumentCommand{\examtype}{ m }{\csdef{src2exam@examtype}{#1}}
\NewDocumentCommand{\lecture}{ m }{\csdef{src2exam@lecture}{#1}}
\NewDocumentCommand{\lecturer}{ m }{\csdef{src2exam@lecturer}{#1}}
\NewDocumentCommand{\semester}{ m }{\csdef{src2exam@semester}{#1}}

\csdef{src2exam@chead}{
    \csuse{src2exam@lecture}
    % Add dash if both lecture and exam type are set.
    \ifcsdef{src2exam@examtype}{\ifcsdef{src2exam@lecture}{~--~}{}}{}
    \csuse{src2exam@examtype}
}

% Default exam title, can be overridden by using \examtitle in the preamble.
\examtitle{\csuse{src2exam@chead}}

% Cover page.
% TODO: Refine
\NewDocumentCommand{\coverpage}{}{
    \begin{titlepage}
        \centering
        {\huge\textbf{\csuse{src2exam@examtitle}}} \\
        \ifsolutionsT{%
            \vspace*{0.5cm}
            {\Large\textbf{\csuse{src2exam@string@solutions}}}
        }
        \vspace*{0.5cm}
        \hrule
        \vspace*{0.5cm}
        \begin{tabularx}{\textwidth}{lXlX}
            \textbf{\csuse{src2exam@string@course}:} & \csuse{src2exam@course} &
            \textbf{\csuse{src2exam@string@semester}:} & \csuse{src2exam@semester} \\
            \textbf{\csuse{src2exam@string@date}:} & \csuse{src2exam@examdate} &
            \textbf{\csuse{src2exam@string@lecturer}:} & \csuse{src2exam@lecturer} \\
        \end{tabularx}
    \end{titlepage}
}

% Set up front matter.
\AtBeginDocument{
    \ihead{\csuse{src2exam@course}}
    \chead{\csuse{src2exam@chead}}
    \ohead{\csuse{src2exam@semester}}
}

\ExplSyntaxOff

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Set Defaults and Process Package Options                                             %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ExecuteOptions{disablesolutions}
\ExecuteOptions{en}

\ProcessOptions\relax
